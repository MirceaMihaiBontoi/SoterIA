<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.soteria.ui.controller.ChatController"
           styleClass="voice-shell">

    <!-- Voice-first shell: top bar + centered face + mic FAB row -->
    <VBox>

        <!-- Top bar: brand + AI status pill -->
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="10" right="12" bottom="10" left="14"/></padding>
            <Button fx:id="historyButton" onAction="#toggleHistorySidebar" styleClass="icon-button">
                <graphic><FontIcon iconLiteral="mdal-history" iconSize="20" styleClass="fab-icon-alt"/></graphic>
            </Button>
            <Label text="SoterIA" styleClass="brand-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox fx:id="statusPill" styleClass="status-pill" alignment="CENTER" spacing="6">
                <padding><Insets top="5" right="10" bottom="5" left="9"/></padding>
                <Circle fx:id="statusDot" radius="4" styleClass="status-dot"/>
                <Label fx:id="aiStatusLabel" text="Preparando" styleClass="status-pill-label"/>
                <Button fx:id="ttsToggle" onAction="#toggleTTS" styleClass="icon-button-mini">
                    <graphic><FontIcon fx:id="ttsIcon" iconLiteral="mdmz-volume_up" iconSize="16" styleClass="fab-icon-alt"/></graphic>
                </Button>
            </HBox>
        </HBox>

        <!-- Centered face + subtitle + partial transcript -->
        <VBox alignment="CENTER" spacing="18" VBox.vgrow="ALWAYS" styleClass="voice-center">
            <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
            
            <!-- Dynamic Safety Box (Orchestrator Destination) -->
            <VBox fx:id="safetyContainer"
                  alignment="TOP_LEFT"
                  maxWidth="500"
                  managed="false"
                  visible="false"
                  styleClass="safety-box">
                <!-- Steps will be injected here via Java -->
            </VBox>

            <StackPane fx:id="faceHolder" prefWidth="240" prefHeight="240"/>
            <Label fx:id="subtitleLabel" text="Pulsa el micro para hablar" styleClass="subtitle-label"
                   wrapText="true" maxWidth="340" textAlignment="CENTER"/>
            <Label fx:id="partialTranscriptLabel" text="" styleClass="partial-transcript"
                   wrapText="true" maxWidth="340" textAlignment="CENTER"/>
        </VBox>

        <!-- Bottom FAB row: alert (left) + mic (center) + chat (right) -->
        <HBox alignment="CENTER" spacing="24" styleClass="fab-row">
            <padding><Insets top="8" right="12" bottom="22" left="12"/></padding>
            <Button fx:id="alertButton" text="SOS" onAction="#handleEmergencyButton" styleClass="alert-fab"/>
            <Button fx:id="micButton" onAction="#handleVoiceInput" styleClass="mic-fab">
                <graphic><FontIcon fx:id="micIcon" iconLiteral="mdmz-mic" iconSize="28" styleClass="fab-icon"/></graphic>
            </Button>
            <Button fx:id="chatButton" onAction="#toggleChatSheet" styleClass="chat-fab">
                <graphic><FontIcon iconLiteral="mdal-chat" iconSize="20" styleClass="fab-icon"/></graphic>
            </Button>
        </HBox>

    </VBox>

    <!-- Chat bottom sheet: hidden by default; slides up when chat FAB tapped -->
    <VBox fx:id="chatSheet" styleClass="chat-sheet" StackPane.alignment="BOTTOM_CENTER"
          visible="false" managed="false" maxHeight="520">
        <Region styleClass="sheet-grabber" prefHeight="4" maxWidth="60"/>
        <HBox styleClass="sheet-header" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="10" right="16" bottom="10" left="18"/></padding>
            <Label text="Conversación" styleClass="sheet-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#closeChatSheet" styleClass="sheet-close"/>
        </HBox>
        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-scroll">
            <VBox fx:id="chatMessages" spacing="10" styleClass="chat-messages">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
            </VBox>
        </ScrollPane>
        <HBox styleClass="chat-input-bar" alignment="CENTER" spacing="10">
            <padding><Insets top="10" right="14" bottom="14" left="14"/></padding>
            <TextField fx:id="messageInput" promptText="Escribe si no puedes hablar…"
                       HBox.hgrow="ALWAYS" onAction="#handleSendMessage"/>
            <Button fx:id="sendButton" onAction="#handleSendMessage" styleClass="send-button">
                <graphic><FontIcon iconLiteral="mdmz-send" iconSize="18" styleClass="fab-icon"/></graphic>
            </Button>
        </HBox>
    </VBox>

    <!-- History Sidebar: slides from left -->
    <VBox fx:id="historySidebar" styleClass="history-sidebar" StackPane.alignment="CENTER_LEFT"
          visible="false" managed="false" maxWidth="280">
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-header">
            <padding><Insets top="16" right="16" bottom="16" left="18"/></padding>
            <Label text="Historial" styleClass="sidebar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#toggleHistorySidebar" styleClass="sheet-close"/>
        </HBox>
        <Button text="+ Nueva Emergencia" onAction="#handleNewChat" styleClass="new-chat-button" maxWidth="Infinity">
            <VBox.margin><Insets left="14" right="14" bottom="10"/></VBox.margin>
        </Button>
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="no-bg-scroll">
            <VBox fx:id="sessionList" spacing="4">
                <padding><Insets left="10" right="10"/></padding>
            </VBox>
        </ScrollPane>
    </VBox>

</StackPane>

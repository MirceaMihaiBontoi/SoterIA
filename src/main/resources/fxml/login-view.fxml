<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.emergencias.ui.LoginController" 
      styleClass="login-panel" alignment="CENTER" spacing="25">
    
    <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>
    
    <!-- Logo y título -->
    <Label text="🚨" styleClass="login-logo"/>
    <Label text="Sistema de Emergencias" styleClass="login-title"/>
    <Label text="Inicia sesión para continuar" styleClass="login-subtitle"/>
    
    <!-- Formulario de Login -->
    <VBox fx:id="loginForm" spacing="15" alignment="CENTER">
        <TextField fx:id="loginUsernameField" promptText="Usuario" styleClass="input-field"/>
        <PasswordField fx:id="loginPasswordField" promptText="Contraseña" styleClass="input-field"/>
        
        <CheckBox fx:id="rememberSessionCheck" text="Recordar sesión" styleClass="remember-checkbox"/>
        
        <Button text="Iniciar Sesión" onAction="#handleLogin" styleClass="primary-button" maxWidth="Infinity"/>
        
        <Label fx:id="loginErrorLabel" text="" styleClass="error-label"/>
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="¿No tienes cuenta?" styleClass="text-secondary"/>
            <Label text="Regístrate" styleClass="link-label" onMouseClicked="#showRegisterForm"/>
        </HBox>
    </VBox>
    
    <!-- Formulario de Registro (oculto inicialmente) -->
    <VBox fx:id="registerForm" spacing="12" alignment="CENTER" visible="false">
        <Label text="Crear Cuenta" styleClass="form-title"/>
        
        <TextField fx:id="registerUsernameField" promptText="Usuario" styleClass="input-field"/>
        <PasswordField fx:id="registerPasswordField" promptText="Contraseña" styleClass="input-field"/>
        <PasswordField fx:id="registerConfirmField" promptText="Confirmar contraseña" styleClass="input-field"/>
        <TextField fx:id="registerNameField" promptText="Nombre completo" styleClass="input-field"/>
        <TextField fx:id="registerPhoneField" promptText="Teléfono" styleClass="input-field"/>
        <TextField fx:id="registerContactField" promptText="Contacto de emergencia" styleClass="input-field"/>
        <TextArea fx:id="registerMedicalField" promptText="Información médica (opcional)" prefRowCount="2" styleClass="input-field"/>
        
        <Button text="Crear Cuenta" onAction="#handleRegister" styleClass="success-button" maxWidth="Infinity"/>
        
        <Label fx:id="registerErrorLabel" text="" styleClass="error-label"/>
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="¿Ya tienes cuenta?" styleClass="text-secondary"/>
            <Label text="Inicia sesión" styleClass="link-label" onMouseClicked="#showLoginForm"/>
        </HBox>
    </VBox>
    
</VBox>